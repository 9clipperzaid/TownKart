# Server-side Supabase secrets
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-side public Supabase values
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Optional public client values
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY="your-google-maps-browser-key"
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID="your-google-maps-tracking-id"

# Optional OpenWA WhatsApp order notifications
# Example URL for Docker/local OpenWA: http://localhost:2785
OPENWA_API_URL="http://localhost:2785"
OPENWA_API_KEY="your-openwa-api-key"
OPENWA_SESSION_ID="default"
ORDER_WHATSAPP_PHONE="919999999999"
# Optional if your OpenWA Swagger shows a different send-text route:
OPENWA_SEND_TEXT_PATH="/api/sessions/{sessionId}/messages/send-text"
