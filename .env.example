# Server-side Supabase secrets
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-side public Supabase values
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Optional public client values
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY="your-google-maps-browser-key"
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID="your-google-maps-tracking-id"

# Optional Firebase Cloud Messaging admin credentials for order push popups
FIREBASE_PROJECT_ID="town-kart"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@town-kart.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
